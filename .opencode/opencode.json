{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "provider": {
    "lmstudio": {
      "api": "openai",
      "options": {
        "baseURL": "http://host.docker.internal:1234/v1"
      },
      "models": {
        "qwen3.6-35b-a3b": {
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "limit": {
            "output": 16384,
            "context": 105000
          }
        },
        "huihui-qwen3.6-35b-a3b-abliterated": {
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "limit": {
            "output": 16384,
            "context": 58000
          }
        },
        "ornith-1.0-35b": {
          "limit": {
            "output": 16384,
            "context": 95000
          }
        }
      }
    }
  },
  "permission": {
    "doom_loop": "allow",
    "*": "allow",
    "skill": {
      "*": "allow"
    },
    "bash": {
      "git diff *": "allow",
      "git log *": "allow",
      "git status *": "allow",
      "git *": "ask",
      "curl *": "ask",
      "wget *": "ask",
      "ssh *": "ask",
      "*": "allow"
    }
  }
}
